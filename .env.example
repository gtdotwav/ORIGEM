# Auth — NextAuth v5
AUTH_SECRET=           # openssl rand -base64 32
AUTH_ALLOW_REGISTRATION=false  # true to allow new self-service accounts after bootstrap
AUTH_GITHUB_ID=        # GitHub OAuth App → Client ID
AUTH_GITHUB_SECRET=    # GitHub OAuth App → Client Secret
AUTH_GOOGLE_ID=        # Google OAuth Client ID
AUTH_GOOGLE_SECRET=    # Google OAuth Client Secret

# Optional auth persistence path for local/dev (defaults to .data/origem-auth.json)
ORIGEM_AUTH_PATH=

# Vercel Blob (production persistence)
BLOB_READ_WRITE_TOKEN=

# Encryption key for API keys at rest
ORIGEM_ENCRYPT_SECRET= # openssl rand -base64 32 (required to persist provider/MCP credentials)

# Integrations
VERCEL_API_TOKEN=      # Vercel API token for deployment integration
VERCEL_PROJECT_ID=     # Vercel project ID (prj_...)
VERCEL_TEAM_ID=        # Vercel team ID (team_...)
OPENAI_API_KEY=        # OpenAI API key (fallback for provider store)
